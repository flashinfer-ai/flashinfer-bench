#!/bin/bash
# gpu-lock: Per-GPU mutex wrapper for flashinfer-bench workload collection.
# Allocates N real GPUs from the pool of 8 B200s and runs a command with them.
#
# Usage:
#   gpu-lock [--gpus N] <command> [args...]
#   gpu-lock --status
#
# Options:
#   --gpus <N>            Number of GPUs to allocate (default: 1). Use for TP=N jobs.
#   --timeout <sec>       Max seconds to wait for N GPUs to be free (default: 7200)
#   --exec-timeout <sec>  Max seconds the command can run (default: 3600, 0=disabled)
#   --no-wait             Fail immediately if N GPUs are not available
#   --status              Show which GPUs are locked and by whom
#
# Behaviour:
#   - Acquires N per-GPU lock files (/tmp/flashinfer-bench-gpu-{0..7}.lock)
#   - Sets CUDA_VISIBLE_DEVICES to the allocated GPU indices
#   - Locks are always acquired in ascending GPU-ID order to avoid deadlocks
#   - On exit the locks are released automatically
#
# Examples:
#   gpu-lock -- python scripts/collect_workloads.py sglang ...          # 1 GPU
#   gpu-lock --gpus 4 -- python scripts/collect_workloads.py sglang ... # 4 GPUs (TP=4)
#   gpu-lock --gpus 8 -- python scripts/collect_workloads.py sglang ... # all 8 GPUs (TP=8)
#   gpu-lock --status

set -euo pipefail

NUM_GPUS_TOTAL=8
LOCK_PREFIX="/tmp/flashinfer-bench-gpu"
INFO_PREFIX="/tmp/flashinfer-bench-gpu"
GPUS_NEEDED=1
TIMEOUT=7200
EXEC_TIMEOUT=3600
NO_WAIT=false
STATUS_ONLY=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --gpus)
            GPUS_NEEDED="$2"; shift 2 ;;
        --timeout)
            TIMEOUT="$2"; shift 2 ;;
        --exec-timeout)
            EXEC_TIMEOUT="$2"; shift 2 ;;
        --no-wait)
            NO_WAIT=true; shift ;;
        --status)
            STATUS_ONLY=true; shift ;;
        --)
            shift; break ;;
        *)
            break ;;
    esac
done

# ── Status ─────────────────────────────────────────────────────────────────────
if $STATUS_ONLY; then
    echo "GPU pool: ${NUM_GPUS_TOTAL} × B200"
    for i in $(seq 0 $((NUM_GPUS_TOTAL - 1))); do
        lockfile="${LOCK_PREFIX}-${i}.lock"
        infofile="${INFO_PREFIX}-${i}.info"
        touch "$lockfile"
        if flock -n "$lockfile" true 2>/dev/null; then
            echo "  GPU $i: FREE"
        else
            echo "  GPU $i: LOCKED"
            [ -f "$infofile" ] && sed 's/^/    /' "$infofile"
        fi
    done
    exit 0
fi

if [[ $# -eq 0 ]]; then
    echo "Usage: gpu-lock [--gpus N] [--timeout N] [--exec-timeout N] [--no-wait] [--] <cmd> [args...]" >&2
    echo "       gpu-lock --status" >&2
    exit 1
fi

# ── Allocate N GPUs ────────────────────────────────────────────────────────────
# Returns a space-separated list of GPU indices that were locked, via stdout.
# Blocks until N GPUs are available or timeout expires.
# Locks are acquired in ascending order to prevent deadlocks.

# Create lock files (touch so flock can open them)
for i in $(seq 0 $((NUM_GPUS_TOTAL - 1))); do
    touch "${LOCK_PREFIX}-${i}.lock"
done

# Open all lock file descriptors (FDs 20-27)
for i in $(seq 0 $((NUM_GPUS_TOTAL - 1))); do
    eval "exec $((20 + i))>\"${LOCK_PREFIX}-${i}.lock\""
done

# Try to grab exactly GPUS_NEEDED non-overlapping GPU locks
acquired_gpus=()
acquired_fds=()

try_acquire() {
    acquired_gpus=()
    acquired_fds=()
    for i in $(seq 0 $((NUM_GPUS_TOTAL - 1))); do
        fd=$((20 + i))
        if flock -n $fd 2>/dev/null; then
            acquired_gpus+=($i)
            acquired_fds+=($fd)
            if [[ ${#acquired_gpus[@]} -eq $GPUS_NEEDED ]]; then
                return 0
            fi
        fi
    done
    # Not enough — release what we grabbed
    for fd in "${acquired_fds[@]}"; do
        flock -u $fd 2>/dev/null || true
    done
    acquired_gpus=()
    acquired_fds=()
    return 1
}

release_all() {
    for fd in "${acquired_fds[@]:-}"; do
        flock -u $fd 2>/dev/null || true
    done
    for gpu in "${acquired_gpus[@]:-}"; do
        rm -f "${INFO_PREFIX}-${gpu}.info"
    done
}

if $NO_WAIT; then
    if ! try_acquire; then
        echo "ERROR: ${GPUS_NEEDED} GPU(s) not available (--no-wait). Run 'gpu-lock --status'." >&2
        exit 1
    fi
else
    deadline=$((SECONDS + TIMEOUT))
    interval=5
    printed_wait=false
    while true; do
        if try_acquire; then
            $printed_wait && echo "GPU lock acquired (GPUs: ${acquired_gpus[*]})." >&2
            break
        fi
        if [[ $SECONDS -ge $deadline ]]; then
            echo "ERROR: Timed out waiting for ${GPUS_NEEDED} GPU(s) after ${TIMEOUT}s." >&2
            exit 1
        fi
        if ! $printed_wait; then
            echo "Waiting for ${GPUS_NEEDED} GPU(s) (timeout=${TIMEOUT}s, have $(nvidia-smi --query-compute-apps=gpu_uuid --format=csv,noheader 2>/dev/null | wc -l) in use)..." >&2
            printed_wait=true
        fi
        sleep $interval
    done
fi

# ── Write info files ───────────────────────────────────────────────────────────
for gpu in "${acquired_gpus[@]}"; do
    cat > "${INFO_PREFIX}-${gpu}.info" <<EOF
  PID:        $$
  GPUs:       ${acquired_gpus[*]}
  User:       $(whoami)
  Command:    $*
  Since:      $(date '+%Y-%m-%d %H:%M:%S')
  Exec limit: ${EXEC_TIMEOUT}s
EOF
done

# ── Run command with CUDA_VISIBLE_DEVICES set ──────────────────────────────────
cuda_devices=$(IFS=,; echo "${acquired_gpus[*]}")
export CUDA_VISIBLE_DEVICES="$cuda_devices"

trap release_all EXIT

echo "Running on GPU(s): ${cuda_devices} → CUDA_VISIBLE_DEVICES=${cuda_devices}" >&2

if [[ "$EXEC_TIMEOUT" -gt 0 ]]; then
    timeout --signal=KILL "$EXEC_TIMEOUT" "$@"
    status=$?
    if [[ $status -eq 137 ]]; then
        echo "ERROR: Command killed after ${EXEC_TIMEOUT}s execution timeout." >&2
        exit 137
    fi
    exit $status
else
    "$@"
fi
