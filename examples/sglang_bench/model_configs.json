                "--trust-remote-code",
                "--attention-backend", "flashinfer",
                "--tp-size", "8",
                "--moe-runner-backend", "triton",
                "--tool-call-parser", "kimi_k2",
                "--reasoning-parser", "kimi_k2"
            ]
        },
